# =============================================================
# FILE: .env.example
# -------------------------------------------------------------
# This file is a TEMPLATE for your environment variables.
# 1. Copy this file and rename it to ".env"
# 2. Fill in your actual secrets (do NOT commit .env to Git)
# =============================================================

# SERVER CONFIGURATION
PORT=3000

# DATABASE CONNECTION
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# Example: postgresql://johndoe:mypassword@localhost:5432/airbnb_clone?schema=public
DATABASE_URL="postgresql://user:password@localhost:5432/db_name?schema=public"

# AUTHENTICATION (If needed later)
# JWT_SECRET="your_super_secret_random_string_here"
