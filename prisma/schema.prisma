generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  // url      = env("DATABASE_URL")
}

model User {
  id               Int            @id @default(autoincrement())
  name             String
  email            String         @unique
  username         String         @unique
  phone            String
  role             Role           @default(GUEST)
  password         String
  resetToken       String?
  resetTokenExpiry DateTime?
  avatar           String?
  avatarPublicId   String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  profile          Profile?
  listings         Listing[]      @relation("HostListings")
  bookings         Booking[]
  reviews          Review[]

  @@index([name])
  @@index([role])
}

enum Role {
  ADMIN
  HOST
  GUEST
}

model Profile {
  id      Int     @id @default(autoincrement())
  bio     String?
  website String?
  country String?
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId  Int     @unique
}

model Listing {
  id            Int            @id @default(autoincrement())
  title         String
  description   String
  location      String
  pricePerNight Float
  guests        Int
  type          ListingType
  amenities     String
  rating        Float?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  
  // FIXED: Removed duplicate 'user' relation. Using 'host' consistently.
  host          User           @relation("HostListings", fields: [hostId], references: [id], onDelete: Cascade)
  hostId        Int
  
  photos        ListingPhoto[]
  bookings      Booking[]
  reviews       Review[]

  @@index([hostId])
  @@index([location])
  @@index([type])
  @@index([pricePerNight])
}

model ListingPhoto {
  id        Int     @id @default(autoincrement())
  url       String
  publicId  String
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  listingId Int
}

model Booking {
  id         Int           @id @default(autoincrement())
  checkIn    DateTime
  // FIXED: Using camelCase 'checkOut' to match your validators
  checkOut   DateTime
  totalPrice Float
  status     BookingStatus @default(CONFIRMED)
  createdAt  DateTime      @default(now())

  // RELATIONS
  guest      User          @relation(fields: [guestId], references: [id], onDelete: Restrict)
  guestId    Int
  listing    Listing       @relation(fields: [listingId], references: [id], onDelete: Restrict)
  listingId  Int

  @@index([guestId])
  @@index([listingId])
}

model Review {
  id        Int      @id @default(autoincrement())
  rating    Int
  comment   String
  userId    Int
  listingId Int
  user      User     @relation(fields: [userId], references: [id])
  listing   Listing  @relation(fields: [listingId], references: [id])
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([listingId])
}

enum ListingType {
  APARTMENT
  HOUSE
  VILLA
  CABIN
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}
