generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String    @id @default(uuid()) // ✅ FIXED
  name             String
  email            String    @unique
  username         String    @unique
  phone            String
  role             Role      @default(GUEST)
  password         String
  resetToken       String?
  resetTokenExpiry DateTime?
  avatar           String?
  avatarPublicId   String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  profile          Profile?
  listings         Listing[] @relation("HostListings")
  bookings         Booking[]
  reviews          Review[]

  @@index([name])
  @@index([role])
}

enum Role {
  ADMIN
  HOST
  GUEST
}

model Profile {
  id      String  @id @default(uuid()) // ✅ FIXED (was missing @id)
  bio     String?
  website String?
  country String?

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId  String  @unique // ✅ FIXED (was Int)
}

model Listing {
  id            String    @id @default(uuid()) // already correct
  title         String
  description   String
  location      String
  pricePerNight Float
  guests        Int
  type          ListingType
  amenities     String
  rating        Float?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  host          User      @relation("HostListings", fields: [hostId], references: [id], onDelete: Cascade)
  hostId        String

  photos        ListingPhoto[]
  bookings      Booking[]
  reviews       Review[]

  @@index([hostId])
  @@index([location])
  @@index([type])
  @@index([pricePerNight])
}

model ListingPhoto {
  id        String   @id @default(uuid()) // ✅ FIXED
  url       String
  publicId  String

  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  listingId String  // ✅ FIXED
}

model Booking {
  id         String         @id @default(uuid()) // ✅ FIXED
  checkIn    DateTime
  checkOut   DateTime
  totalPrice Float
  status     BookingStatus @default(CONFIRMED)
  createdAt  DateTime      @default(now())

  guest      User    @relation(fields: [guestId], references: [id], onDelete: Restrict)
  guestId    String  // ✅ FIXED

  listing    Listing @relation(fields: [listingId], references: [id], onDelete: Restrict)
  listingId  String  // ✅ FIXED

  @@index([guestId])
  @@index([listingId])
}

model Review {
  id        String   @id @default(uuid()) // ✅ FIXED
  rating    Int
  comment   String

  userId    String   // ✅ FIXED
  listingId String   // ✅ FIXED

  user      User     @relation(fields: [userId], references: [id])
  listing   Listing  @relation(fields: [listingId], references: [id])

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([listingId])
}

enum ListingType {
  APARTMENT
  HOUSE
  VILLA
  CABIN
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}